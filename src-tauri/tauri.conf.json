{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noteszen",
  "version": "0.1.0",
  "identifier": "com.noteszen.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NotesZen",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "decorations": false,
        "resizable": true
      },
      {
        "label": "quick-capture",
        "title": "Quick Capture",
        "width": 500,
        "height": 200,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "url": "index.html#quick-capture"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
